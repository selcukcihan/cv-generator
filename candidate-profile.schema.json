{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./candidate-profile.schema.json",
  "title": "Candidate Profile",
  "description": "Minimal structured candidate profile used as the source of truth for CV generation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "basics",
    "experience",
    "education",
    "certifications",
    "skills",
    "references",
    "generation_preferences"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "basics": {
      "$ref": "#/$defs/basics"
    },
    "summary": {
      "$ref": "#/$defs/nullable_string"
    },
    "experience": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/experience_item"
      }
    },
    "education": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/education_item"
      }
    },
    "certifications": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/certification_item"
      }
    },
    "skills": {
      "$ref": "#/$defs/string_list"
    },
    "references": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reference_item"
      }
    },
    "generation_preferences": {
      "$ref": "#/$defs/generation_preferences"
    }
  },
  "$defs": {
    "nullable_string": {
      "type": [
        "string",
        "null"
      ]
    },
    "string_list": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "basics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "full_name",
        "current_title",
        "email",
        "url"
      ],
      "properties": {
        "full_name": {
          "type": "string",
          "minLength": 1
        },
        "current_title": {
          "$ref": "#/$defs/nullable_string"
        },
        "email": {
          "$ref": "#/$defs/nullable_string"
        },
        "url": {
          "$ref": "#/$defs/nullable_string"
        }
      }
    },
    "experience_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "company",
        "dates",
        "url",
        "descriptions"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "company": {
          "type": "string",
          "minLength": 1
        },
        "dates": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "$ref": "#/$defs/nullable_string"
        },
        "descriptions": {
          "$ref": "#/$defs/string_list"
        }
      }
    },
    "education_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "institution",
        "degree",
        "field_of_study"
      ],
      "properties": {
        "institution": {
          "type": "string",
          "minLength": 1
        },
        "degree": {
          "type": "string",
          "minLength": 1
        },
        "field_of_study": {
          "$ref": "#/$defs/nullable_string"
        }
      }
    },
    "certification_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "issuer",
        "expiration_date"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "issuer": {
          "type": "string",
          "minLength": 1
        },
        "expiration_date": {
          "$ref": "#/$defs/nullable_string"
        }
      }
    },
    "reference_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "title",
        "contact",
        "summary"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "$ref": "#/$defs/nullable_string"
        },
        "contact": {
          "$ref": "#/$defs/nullable_string"
        },
        "summary": {
          "$ref": "#/$defs/nullable_string"
        }
      }
    },
    "generation_preferences": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_length",
        "include_projects",
        "tone_preferences"
      ],
      "properties": {
        "max_length": {
          "type": "string",
          "enum": [
            "one_page",
            "two_pages",
            "minimal"
          ]
        },
        "include_projects": {
          "type": "string",
          "enum": [
            "always",
            "never",
            "only_when_helpful"
          ]
        },
        "tone_preferences": {
          "$ref": "#/$defs/string_list"
        }
      }
    }
  }
}
