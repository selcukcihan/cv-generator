{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./candidate-profile.schema.json",
  "title": "Candidate Profile",
  "description": "Minimal structured candidate profile used as the source of truth for CV generation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "basics",
    "experience",
    "education",
    "certifications",
    "skills",
    "references",
    "generation_preferences"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "basics": {
      "$ref": "#/$defs/basics"
    },
    "summary": {
      "$ref": "#/$defs/nullable_string"
    },
    "experience": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/experience_item"
      }
    },
    "education": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/education_item"
      }
    },
    "certifications": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/certification_item"
      }
    },
    "skills": {
      "$ref": "#/$defs/string_list"
    },
    "references": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reference_item"
      }
    },
    "generation_preferences": {
      "$ref": "#/$defs/generation_preferences"
    }
  },
  "$defs": {
    "nullable_string": {
      "type": [
        "string",
        "null"
      ]
    },
    "string_list": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "basics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "full_name",
        "current_title",
        "location",
        "email",
        "url"
      ],
      "properties": {
        "full_name": {
          "type": "string",
          "minLength": 1
        },
        "current_title": {
          "$ref": "#/$defs/nullable_string"
        },
        "location": {
          "$ref": "#/$defs/nullable_string"
        },
        "email": {
          "$ref": "#/$defs/nullable_string"
        },
        "url": {
          "$ref": "#/$defs/nullable_string"
        }
      }
    },
    "experience_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "company",
        "company_type",
        "industry",
        "title",
        "location",
        "employment_type",
        "start_date",
        "end_date",
        "still_employed",
        "team_or_org",
        "scope",
        "achievements",
        "additional_notes"
      ],
      "properties": {
        "company": {
          "type": "string",
          "minLength": 1
        },
        "company_type": {
          "$ref": "#/$defs/nullable_string"
        },
        "industry": {
          "$ref": "#/$defs/nullable_string"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "location": {
          "$ref": "#/$defs/nullable_string"
        },
        "employment_type": {
          "$ref": "#/$defs/nullable_string"
        },
        "start_date": {
          "type": "string",
          "minLength": 1
        },
        "end_date": {
          "$ref": "#/$defs/nullable_string"
        },
        "still_employed": {
          "type": "boolean"
        },
        "team_or_org": {
          "$ref": "#/$defs/nullable_string"
        },
        "scope": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "responsibilities",
            "product_or_platform_context",
            "users_or_customers",
            "scale",
            "ownership_area"
          ],
          "properties": {
            "responsibilities": {
              "$ref": "#/$defs/string_list"
            },
            "product_or_platform_context": {
              "$ref": "#/$defs/nullable_string"
            },
            "users_or_customers": {
              "$ref": "#/$defs/nullable_string"
            },
            "scale": {
              "$ref": "#/$defs/nullable_string"
            },
            "ownership_area": {
              "$ref": "#/$defs/nullable_string"
            }
          }
        },
        "achievements": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/achievement_item"
          }
        },
        "additional_notes": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "awards_or_recognition"
          ],
          "properties": {
            "awards_or_recognition": {
              "$ref": "#/$defs/string_list"
            }
          }
        }
      }
    },
    "achievement_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "what_changed",
        "why_it_mattered",
        "metric_or_proof",
        "technologies_used",
        "scope_or_scale"
      ],
      "properties": {
        "what_changed": {
          "type": "string",
          "minLength": 1
        },
        "why_it_mattered": {
          "$ref": "#/$defs/nullable_string"
        },
        "metric_or_proof": {
          "$ref": "#/$defs/nullable_string"
        },
        "technologies_used": {
          "$ref": "#/$defs/string_list"
        },
        "scope_or_scale": {
          "$ref": "#/$defs/nullable_string"
        }
      }
    },
    "education_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "institution",
        "degree",
        "field_of_study"
      ],
      "properties": {
        "institution": {
          "type": "string",
          "minLength": 1
        },
        "degree": {
          "type": "string",
          "minLength": 1
        },
        "field_of_study": {
          "$ref": "#/$defs/nullable_string"
        }
      }
    },
    "certification_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "issuer",
        "expiration_date",
        "relevance"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "issuer": {
          "type": "string",
          "minLength": 1
        },
        "expiration_date": {
          "$ref": "#/$defs/nullable_string"
        },
        "relevance": {
          "$ref": "#/$defs/nullable_string"
        }
      }
    },
    "reference_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "contact",
        "about",
        "relation"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "contact": {
          "$ref": "#/$defs/nullable_string"
        },
        "about": {
          "$ref": "#/$defs/nullable_string"
        },
        "relation": {
          "$ref": "#/$defs/nullable_string"
        }
      }
    },
    "generation_preferences": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_length",
        "include_projects",
        "tone_preferences"
      ],
      "properties": {
        "max_length": {
          "type": "string",
          "enum": [
            "one_page",
            "two_pages",
            "minimal"
          ]
        },
        "include_projects": {
          "type": "string",
          "enum": [
            "always",
            "never",
            "only_when_helpful"
          ]
        },
        "tone_preferences": {
          "$ref": "#/$defs/string_list"
        }
      }
    }
  }
}
